---
// This is Astro's frontmatter
// here you can write regular JavaScript or TypeScript
// It will only run on the server and never executes client-side

import Layout from '../layouts/Layout.astro';
import Header from './header.astro';
import YearSelect from '../components/YearSelect.astro';
import CancerTypeSelect from '../components/CancerTypeSelect.astro';
import SexSelect from '../components/SexSelect.astro';
import DeprivationTable from '../components/DeprivationTable.astro';
import RegionSelectOpt from '../components/RegionSelectOpt.astro';
---

<Layout>
  	<Header />

    <div class="dashboard-container">
        <!- top left: panel area -->
        <div id="panel">

			<h1 class="is-size-3">Search by Cancer Type, Stage and Year</h1>
			<hr/>
  			<h2 class="is-size-5 mb-2">Select your search criteria</h2>
			<form id="stage-search-form">

				<CancerTypeSelect />

				<div class="select">
					<select id="stage-input">
						<option disabled selected>Select stage...</option>
						<option = "Early Stage">Early Stage</option>
						<option = "Advanced Stage">Advanced Stage</option>
					</select>
				</div>

				<YearSelect />
				
				<hr />
				<div class="mb-2">Add optional Sex</div>
				<SexSelect />
				<hr />
				<div class="mb-2">Add optional Region</div>
				<RegionSelectOpt />

				<hr />

				<div class="mb-2">
					<input class="button" type="submit" value="Search" />
				    <input class="button" type="reset" value="Reset" />
				</div>	
			</form>
		</div>
		
        <!-- bottom left, below map -->
        <div id="bottom-panel" class="grid-panel">
           	<DeprivationTable />    
        </div>

        <!-- right side, stretches full height -->
        <div id="right-panel" class="grid-panel">
            <h2>Main Data Area</h2>

			<!-- Output target container for chart -->
			<div id="csv-chart" style="width: 100%; height: 400px;"></div>

			<!-- Output target container for  first table -->
			<div id="search-results" style="width: 100%; height: 250px;"></div>
			<div id="search-results-two" style="width: 100%; height: 250px;"></div>
			
        </div>
    </div>

</Layout>

<script>
  // Import PapaParse directly into your client bundle
	import Papa from 'papaparse';
	import * as echarts from 'echarts';
	import type { CSVRow } from '../types';
	import { filterArray, cancerType, generateTable, dataMap } from "../utils/filter";

    const chartDom = document.getElementById('csv-chart');
	const myChart = echarts.init(chartDom);

	const stage_form = document.getElementById('stage-search-form') as HTMLFormElement;
	const stage_input = document.getElementById('stage-input') as HTMLInputElement;
	const year_input = document.getElementById('year-input') as HTMLInputElement;
	const cancer_type = document.getElementById('cancer-type') as HTMLInputElement;
	const male_checkbox = document.getElementById('maleckbox') as HTMLInputElement;
	const female_checkbox = document.getElementById('femaleckbox') as HTMLInputElement;
	const region_input = document.getElementById('region-input') as HTMLInputElement;
	const resultsContainer = document.getElementById('search-results');	
	const resultsContainerTwo = document.getElementById('search-results-two');	

	const button = document.getElementById('download-btn');


  	stage_form?.addEventListener('submit', async (event) => {
    event.preventDefault(); // Stop GitHub Pages from attempting a form redirect
    
    // search only works with case sensitive
	const stage_query = stage_input.value.trim();
    const year_query = year_input.value.trim();

    if (!stage_query || !year_query || !resultsContainer) return;

	/* make unique keys to query with - key_query can hold multiple factors and contain them in one query string. However, to bring back records from both sexes (as opposed to either 'male' or 'female') a second query string is required to bring back a new dataset that can be mapped onto a table. 
	*/
	var key_query = '';
	var key_query_two = '';

	let male_input = '';
	let female_input = '';

    // check the checkboxes buttons
	if(male_checkbox && male_checkbox.checked){
		male_input = 'Male';
	} 
	if(female_checkbox && female_checkbox.checked){
		female_input = 'Female';
	}

	// if only stage has been added
    if (stage_query !== 'Select stage...'  && male_input === '' && female_input === '' && region_input.value === 'Select...'){
		key_query = stage_query + '~';
	}
	// if stage plus region has been added, no sex
	else if(stage_query !== 'Select stage...' && male_input === '' && female_input === '' && region_input.value !== 'Select...'  ){

	    key_query = region_input.value + '/' + stage_query + '*';
	}   
	// if stage plus male sex has been added
	else if(stage_query !== 'Select stage...'  && male_input !== '' && female_input === '' && region_input.value === 'Select...' ){

	    key_query = male_input + '/' + stage_query + '*';
	}
	// if stage plus female sex has been added
	else if(stage_query !== 'Select stage...' &&  male_input === '' && female_input !== '' && region_input.value === 'Select...' ){

	    key_query = female_input + '/' + stage_query + '*';
	}  
	// if stage plus both male and female sex have been added
	else if(stage_query !== 'Select stage...'  && male_input !== '' && female_input !== '' && region_input.value === 'Select...' ){

	    key_query = male_input + '/' + stage_query + '*';
		key_query_two = female_input + '/' +  stage_query + '*';
	}
	// if stage and region plus male sex has been added
	else if(stage_query !== 'Select stage...' &&  male_input !== '' && female_input === '' && region_input.value !== 'Select...' ){

	    key_query = male_input + '/' + region_input.value + '/' + stage_query + '+';
	}  
	// if stage and region plus female sex has been added
	else if(stage_query !== 'Select stage...' &&  male_input === '' && female_input !== '' && region_input.value !== 'Select...' ){

	    key_query = female_input + '/' + region_input.value + '/' + stage_query + '+';
	}  
	// if stage and region plus both male and female sex have been added
	else if(stage_query !== 'Select stage...' &&  male_input !== '' && female_input !== '' && region_input.value !== 'Select...' ){

	    key_query = male_input + '/' + region_input.value + '/' + stage_query + '+';
		key_query_two = female_input + '/' + region_input.value + '/' + stage_query + '+';
	}
	else {
		key_query = stage_query;
	}

    resultsContainer.innerHTML = '<p>Searching records...</p>';

	const CSV_file = cancerType(`${cancer_type.value}`);

    try {
        // get raw CSV data
		const response = await fetch(CSV_file);
		if (!response.ok) throw new Error('Failed to retrieve data file.');
		
		const csvText = await response.text();

		
      // parse CSV text directly into JSON format
      Papa.parse<CSVRow>(csvText, {
        header: true, // Uses row 1 keys mapping row values into key-value objects
        skipEmptyLines: true,
        complete: (results) => {
			const matchedItems = results.data.filter(item => 
				item.table?.includes(key_query) &&
				item.diagnosisYear?.toLowerCase().includes(year_query) 
			);

			// declared in case a second query is needed (optional)
			var matchedItemsSecond: CSVRow[] = [];

			// if we have a second search for the female records
			if(key_query_two !== ''){
				matchedItemsSecond = results.data.filter(item => 
				item.table?.includes(key_query_two) &&
				item.diagnosisYear?.toLowerCase().includes(year_query) 
				);
			}
			
			// returned if matching fails
			if (matchedItems.length === 0 && matchedItemsSecond.length === 0) {
				resultsContainer.innerHTML = '<p>No records found matching that query.</p>';			
				return;
			}

			// filter to catch unwanted extra matches where 'male' also brings back 'female' records
			if(matchedItems.length !== 0){
				filterArray(matchedItems, key_query);
			}

			if(matchedItemsSecond.length !== 0){
				filterArray(matchedItemsSecond, key_query_two);
			}

			if (matchedItems){
				// call generateTable function in utils
				resultsContainer.innerHTML = generateTable(matchedItems);
			}

		    if (matchedItemsSecond && resultsContainerTwo != null){
				resultsContainerTwo.innerHTML = generateTable(matchedItemsSecond);
		    }

			// call function to render an echart
			renderChart(matchedItems, matchedItemsSecond, myChart);

			console.log(matchedItems);
			console.log(matchedItemsSecond);
		
        },
        error: (error: Error) => {
          resultsContainer.innerHTML = `<p style="color: red;">Parsing error: ${error.message}</p>`;
        }
      });

    } catch (err) {
      resultsContainer.innerHTML = '<p style="color: red;">Could not fetch CSV file.</p>';
      console.error(err);
    }
  });


  // function to initialize the EChart
  function renderChart(data: any[], dataSecond: any[], chartInstance: echarts.ECharts) {
    
    const year = data.map((row: { diagnosisYear: any; }) => row.diagnosisYear).filter(Boolean);
    const stage = data.map((row: { table: any; }) => row.table).filter(Boolean);
	// convert object to string for the slice later
    var stageString = stage.toString();

	// create arrays of arrays
	const ages = dataMap(data);
	const agesSecond = dataMap(dataSecond);
	// flatten each to a single array
	const ageSeries = ages.flat(1);
	const ageSeriesTwo = agesSecond.flat(1);

    const option = {
      title: {
        text: stageString.slice(0, -1) + ' Incidents by Age - Diagnosis Year : ' + year 
      },
      tooltip: {
        trigger: 'axis'
      },
      xAxis: {
        type: 'category',
        data: ["0-49", "50-54", "55-59", "60-64", "65-69", "70-74", "75-79", "80-84", "85-89", "90+"]
      },
      yAxis: {
        type: 'value'
      },
      series: [
        {
          data: ageSeries,
          type: 'line',
          smooth: true
        },
		{
          data: ageSeriesTwo,
          type: 'line',
          smooth: true
        } 
      ]
    };

    // Set options to render the chart
    chartInstance.setOption(option);

    // Optional: Make the chart responsive to window resizing
    window.addEventListener('resize', () => {
      chartInstance.resize();
    });
  }
</script>

<style>

	#download-btn {
		margin-top: 40px;
	}

	#csv-search-form {
		display: flex; 
		gap: 0.5rem; 
		margin-top: 1.5rem;
	}

	/* A responsive 2x2 grid container */
	.dashboard-container {
		display: grid;
		height: 100vh;
		width: 100vw;
		/* splits screen horizontally, favoring left side a little */
		grid-template-columns: 25fr 75fr;
		/* splits screen vertically, favoring the top a little */
		grid-template-rows: 65fr 35fr;
	}

	/* individual grid panels */
	.grid-panel {
		background: #ffffff;
		border: 1px solid #e2e8f0;
		box-sizing: border-box;
		overflow: auto;
		padding: 20px;
	}

	#panel {
		padding-left: 20px;
		padding-top: 20px;
	}


	/* bottom left below the map */
	#bottom-panel {
		grid-column: 1;
		grid-row: 2;
		background: #fff;
	}

	/* right side goes from top to bottom, place for data? */
	#right-panel {
		grid-column: 2;
		grid-row: 1 / span 2;
		background: #fdfdfd;
		border-left: 2px solid #cbd5e0;
	}

	/* responsiveness... */
	@media (max-width: 768px) {
		.dashboard-container {
			display: flex;
			flex-direction: column;
			height: auto;
			overflow-y: auto;
		}
		html, body { overflow: auto; height: auto; }
		#map { height: 400px; }
		#bottom-panel, #right-panel { height: auto; width: 100%; border-left: none; border-top: 1px solid #cbd5e0; }
	}

	
	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
	}


</style>
